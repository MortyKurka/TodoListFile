{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": 
  [
    {
      "src": "src/*.csproj",
      "output": "docs/api"
    }
  ],
  "build": 
  {
    "content": 
    [
      {
        "files": ["docs/api/*.yml"]
      },
      {
        "files": ["toc.yml", "*.md"]
      }
    ],
    "resource": 
    [
      {
        "files": ["docs/images/**"]
      }
    ],
    "output": "docs/_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "Todo-list",
      "_appTitle": "Todo-list",
      "_enableSearch": true
    }
  }
}